        <mxCell id="fnn_1" value="&lt;b&gt;1FN - Primeira Forma Normal&lt;/b&gt;&lt;br&gt;&lt;br&gt;Todos os campos guardam valores simples e indivisíveis. Cada tabela tem uma chave primária que identifica cada registo.&lt;br&gt;&lt;br&gt;&lt;b&gt;Exemplo:&lt;/b&gt; os tamanhos e stocks dos produtos não estão numa lista dentro de Produto; ficam separados em Produto_Tamanho_Stock." style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#e0f2fe;strokeColor=#0369a1;strokeWidth=1.6;fontColor=#111827;fontSize=14;align=left;verticalAlign=top;spacing=16;" vertex="1" parent="1">
          <mxGeometry x="80" y="2720" width="430" height="230" as="geometry" />
        </mxCell>
        <mxCell id="fnn_2" value="&lt;b&gt;2FN - Segunda Forma Normal&lt;/b&gt;&lt;br&gt;&lt;br&gt;Os atributos dependem da chave primária da tabela onde estão. Relações muitos-para-muitos foram transformadas em tabelas próprias.&lt;br&gt;&lt;br&gt;&lt;b&gt;Exemplos:&lt;/b&gt; Favorito_Musica, Seguir_Artista, Produto_Tamanho_Stock e Encomenda_Item." style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#dcfce7;strokeColor=#15803d;strokeWidth=1.6;fontColor=#111827;fontSize=14;align=left;verticalAlign=top;spacing=16;" vertex="1" parent="1">
          <mxGeometry x="585" y="2720" width="430" height="230" as="geometry" />
        </mxCell>
        <mxCell id="fnn_3" value="&lt;b&gt;3FN - Terceira Forma Normal&lt;/b&gt;&lt;br&gt;&lt;br&gt;O modelo evita dependências entre atributos não-chave e reduz duplicação de dados. Informação independente fica em tabelas próprias.&lt;br&gt;&lt;br&gt;&lt;b&gt;Exemplo:&lt;/b&gt; Produto guarda idCategoria, mas o nome da categoria fica apenas em Categoria." style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fef3c7;strokeColor=#b45309;strokeWidth=1.6;fontColor=#111827;fontSize=14;align=left;verticalAlign=top;spacing=16;" vertex="1" parent="1">
          <mxGeometry x="1090" y="2720" width="430" height="230" as="geometry" />
        </mxCell>
        <mxCell id="fnn_e1" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#334155;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="fnn_1" target="fnn_2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fnn_e2" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#334155;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="fnn_2" target="fnn_3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fnn_examples" value="&lt;b&gt;Aplicação no projeto&lt;/b&gt;&lt;br&gt;&lt;br&gt;- Cliente também representa o artista, evitando duplicação de dados pessoais.&lt;br&gt;- Categoria, Tamanho, Pagamento e Morada_Encomenda foram separados em tabelas próprias.&lt;br&gt;- Favoritos, seguidores, produtos por tamanho e itens de encomenda usam tabelas associativas.&lt;br&gt;- Encomenda_Item guarda valores históricos da compra, como preço unitário e nome do produto, para manter recibos corretos mesmo que o produto seja alterado depois." style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f8fafc;strokeColor=#cbd5e1;strokeWidth=1.4;fontColor=#111827;fontSize=14;align=left;verticalAlign=top;spacing=16;" vertex="1" parent="1">
          <mxGeometry x="80" y="3025" width="690" height="210" as="geometry" />
        </mxCell>
        <mxCell id="fnn_conclusion" value="&lt;b&gt;Conclusão para a PAP&lt;/b&gt;&lt;br&gt;&lt;br&gt;A base de dados Greenerry foi organizada até à 3FN. O modelo separa entidades independentes, evita grupos repetidos e usa chaves estrangeiras para representar relações. Esta estrutura melhora a consistência dos dados, reduz duplicação e facilita a manutenção do sistema." style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f8fafc;strokeColor=#cbd5e1;strokeWidth=1.4;fontColor=#111827;fontSize=14;align=left;verticalAlign=top;spacing=16;" vertex="1" parent="1">
          <mxGeometry x="830" y="3025" width="690" height="210" as="geometry" />
        </mxCell>
        <mxCell id="fnn_e3" value="justifica" style="endArrow=block;html=1;rounded=0;strokeWidth=1.6;strokeColor=#64748b;fontColor=#334155;fontSize=12;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="fnn_2" target="fnn_examples">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="800" y="2985" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="fnn_e4" value="resume" style="endArrow=block;html=1;rounded=0;strokeWidth=1.6;strokeColor=#64748b;fontColor=#334155;fontSize=12;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="fnn_3" target="fnn_conclusion">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1300" y="2985" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>