        <mxCell id="ov_reset_2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111827;fontSize=12;align=center;verticalAlign=middle;" value="Verificacao_Email" vertex="1">
          <mxGeometry height="46" width="190" x="1940" y="1270" as="geometry" />
        </mxCell>
        <mxCell id="ov_reset_3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#111827;fontSize=12;align=center;verticalAlign=middle;" value="Recuperacao_Password" vertex="1">
          <mxGeometry height="46" width="205" x="2210" y="1270" as="geometry" />
        </mxCell>
        <mxCell id="ov_reset_e1" edge="1" parent="1" source="ov_reset_1" style="endArrow=block;html=1;rounded=0;strokeWidth=1.4;strokeColor=#111827;fontColor=#111827;fontSize=11;edgeStyle=orthogonalEdgeStyle;" target="ov_reset_2" value="1:N">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ov_reset_e2" edge="1" parent="1" source="ov_reset_1" style="endArrow=block;html=1;rounded=0;strokeWidth=1.4;strokeColor=#111827;fontColor=#111827;fontSize=11;edgeStyle=orthogonalEdgeStyle;" target="ov_reset_3" value="1:N">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1758" y="1340" />
              <mxPoint x="2313" y="1340" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="fnn_title" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffd6d6;strokeColor=#ef4444;fontSize=24;fontStyle=1;fontColor=#000000;align=center;verticalAlign=middle;" value="FNN" vertex="1">
          <mxGeometry height="50" width="110" x="50" y="2590" as="geometry" />
        </mxCell>
        <mxCell id="fnn_subtitle" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#64748b;align=left;verticalAlign=top;whiteSpace=wrap;" value="Formas Normais aplicadas ao modelo da base de dados Greenerry." vertex="1">
          <mxGeometry height="30" width="760" x="50" y="2650" as="geometry" />
        </mxCell>
        <mxCell id="fnn_1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#e0f2fe;strokeColor=#0369a1;strokeWidth=1.6;fontColor=#111827;fontSize=14;align=left;verticalAlign=top;spacing=16;" value="&lt;b&gt;1FN - Primeira Forma Normal&lt;/b&gt;&lt;br&gt;&lt;br&gt;Todos os campos guardam valores simples e indivisíveis. Cada tabela tem uma chave primária que identifica cada registo.&lt;br&gt;&lt;br&gt;&lt;b&gt;Exemplo:&lt;/b&gt; os tamanhos, stocks, imagens e tokens de email/password não ficam em listas dentro de Cliente ou Produto; ficam em tabelas próprias." vertex="1">
          <mxGeometry height="230" width="430" x="80" y="2720" as="geometry" />
        </mxCell>
        <mxCell id="fnn_2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#dcfce7;strokeColor=#15803d;strokeWidth=1.6;fontColor=#111827;fontSize=14;align=left;verticalAlign=top;spacing=16;" value="&lt;b&gt;2FN - Segunda Forma Normal&lt;/b&gt;&lt;br&gt;&lt;br&gt;Os atributos dependem da chave primária da tabela onde estão. Relações muitos-para-muitos foram transformadas em tabelas próprias.&lt;br&gt;&lt;br&gt;&lt;b&gt;Exemplos:&lt;/b&gt; Favorito_Musica, Seguir_Artista, Produto_Tamanho_Stock e Encomenda_Item." vertex="1">
          <mxGeometry height="230" width="430" x="585" y="2720" as="geometry" />
        </mxCell>
        <mxCell id="fnn_3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fef3c7;strokeColor=#b45309;strokeWidth=1.6;fontColor=#111827;fontSize=14;align=left;verticalAlign=top;spacing=16;" value="&lt;b&gt;3FN - Terceira Forma Normal&lt;/b&gt;&lt;br&gt;&lt;br&gt;O modelo evita dependências entre atributos não-chave e reduz duplicação de dados. Informação independente fica em tabelas próprias.&lt;br&gt;&lt;br&gt;&lt;b&gt;Exemplo:&lt;/b&gt; Produto guarda idCategoria, mas o nome da categoria fica apenas em Categoria." vertex="1">
          <mxGeometry height="230" width="430" x="1090" y="2720" as="geometry" />
        </mxCell>
        <mxCell id="fnn_e1" edge="1" parent="1" source="fnn_1" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#334155;edgeStyle=orthogonalEdgeStyle;" target="fnn_2" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fnn_e2" edge="1" parent="1" source="fnn_2" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#334155;edgeStyle=orthogonalEdgeStyle;" target="fnn_3" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fnn_examples" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f8fafc;strokeColor=#cbd5e1;strokeWidth=1.4;fontColor=#111827;fontSize=14;align=left;verticalAlign=top;spacing=16;" value="&lt;b&gt;Aplicação no projeto&lt;/b&gt;&lt;br&gt;&lt;br&gt;- Cliente também representa o artista, evitando duplicação de dados pessoais.&lt;br&gt;- Categoria, Tamanho, Pagamento e Morada_Encomenda foram separados em tabelas próprias.&lt;br&gt;- Verificacao_Email e Recuperacao_Password guardam tokens, expiração e uso fora da tabela Cliente.&lt;br&gt;- Favoritos, seguidores, produtos por tamanho e itens de encomenda usam tabelas associativas.&lt;br&gt;- Encomenda_Item guarda valores históricos da compra, como preço unitário e nome do produto, para manter recibos corretos mesmo que o produto seja alterado depois." vertex="1">
          <mxGeometry height="210" width="690" x="80" y="3025" as="geometry" />
        </mxCell>
        <mxCell id="fnn_conclusion" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f8fafc;strokeColor=#cbd5e1;strokeWidth=1.4;fontColor=#111827;fontSize=14;align=left;verticalAlign=top;spacing=16;" value="&lt;b&gt;Conclusão para a PAP&lt;/b&gt;&lt;br&gt;&lt;br&gt;A base de dados Greenerry foi organizada até à 3FN. O modelo separa entidades independentes, evita grupos repetidos e usa chaves estrangeiras para representar relações. Esta estrutura melhora a consistência dos dados, reduz duplicação e facilita a manutenção do sistema." vertex="1">
          <mxGeometry height="210" width="690" x="830" y="3025" as="geometry" />
        </mxCell>
        <mxCell id="fnn_e3" edge="1" parent="1" source="fnn_2" style="endArrow=block;html=1;rounded=0;strokeWidth=1.6;strokeColor=#64748b;fontColor=#334155;fontSize=12;edgeStyle=orthogonalEdgeStyle;" target="fnn_examples" value="justifica">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="800" y="2985" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="fnn_e4" edge="1" parent="1" source="fnn_3" style="endArrow=block;html=1;rounded=0;strokeWidth=1.6;strokeColor=#64748b;fontColor=#334155;fontSize=12;edgeStyle=orthogonalEdgeStyle;" target="fnn_conclusion" value="resume">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1300" y="2985" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
